<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LoupixDeck.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        x:Class="LoupixDeck.Views.MainWindow"
        x:DataType="vm:MainShellViewModel"
        d:DataContext="{d:DesignInstance Type=vm:MainShellViewModel, IsDesignTimeCreatable=True}"
        Icon="avares://LoupixDeck/Assets/logo.ico"
        Title="LoupixDeck"
        x:Name="RootWindow">
    <Window.Styles>
        <!-- Device touch button chrome. The Razer centre grid relies on this
             window-level style; the Live S layout overrides Button[Tag=Touch]
             locally with a chrome-free variant. -->
        <Style Selector="Button[Tag=Touch]">
            <Setter Property="Background" Value="{DynamicResource DeviceScreenBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DeviceButtonBorder}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="90" />
            <Setter Property="Height" Value="90" />
            <Setter Property="Effect" Value="{StaticResource InnerShadow}" />
        </Style>
        <Style Selector="Button[Tag=Led]">
            <Setter Property="Background" Value="{DynamicResource DeviceScreenBackground}" />
            <Setter Property="Effect" Value="{StaticResource InnerShadow}" />
        </Style>

        <!-- Compact page pager (shared by every device layout): a single name field
             flanked by prev/next chevrons plus add/delete. Constant size regardless
             of how many pages exist, so the window never grows with page count. -->
        <Style Selector="Border.Pager">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceLow}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <!-- Prev/next chevrons and add/delete actions share a chrome-free custom
             template so hover/press never paint the default grey button box. -->
        <Style Selector="Button.PagerBtn">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource AppControlBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PageChipBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.PagerBtn:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundHover}" />
            <Setter Property="BorderBrush" Value="{StaticResource PageActiveBorderBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <!-- Chevrons sit flush either side of the name field (no rounded outer edge). -->
        <Style Selector="Button.PagerNav">
            <Setter Property="FontSize" Value="18" />
        </Style>
        <!-- Delete gets a danger-coloured hover so it reads apart from add. -->
        <Style Selector="Button.PagerBtn.delete:pointerover">
            <Setter Property="Background" Value="#5A2730" />
            <Setter Property="BorderBrush" Value="#B05560" />
            <Setter Property="Foreground" Value="#FF9090" />
        </Style>

        <!-- Editable page-name field at the centre of the pager. Watermark shows the
             page number (PageName fallback) when the page has no custom name. -->
        <Style Selector="TextBox.PageName">
            <Setter Property="Width" Value="128" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <!-- The placeholder (shown when no custom page name is set) defaults to a very
             faint Fluent colour that is hard to read, especially in Light mode. Avalonia 12
             exposes it as TextBox.PlaceholderForeground (an earlier attempt to restyle a
             PART_Watermark TextBlock did nothing — that element no longer exists), so set it
             to the primary text colour so the fallback page name reads like a typed name. -->
        <Style Selector="TextBox.PageName">
            <Setter Property="PlaceholderForeground" Value="{DynamicResource AppTextPrimary}" />
        </Style>

        <!-- "current / total" page counter shown beside the name field. -->
        <Style Selector="TextBlock.PageCount">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="2,0,4,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        </Style>
    </Window.Styles>
    <Design.DataContext>
        <vm:MainShellViewModel />
    </Design.DataContext>

    <!-- The hamburger overlays the device cell (rather than sitting in its own column)
         so its right edge lines up with the body's right edge instead of widening the
         window past the device. The body ends at SVG x=825 of the 900-wide viewBox,
         ~63px in from the 760px Viewbox's right edge. -->
    <Grid RowDefinitions="Auto,*">
        <!-- Device switcher: a dropdown of the running devices. Hidden for a single
             device so the window looks exactly as before (issue #116 phase 3). -->
        <ComboBox Grid.Row="0"
                  HorizontalAlignment="Center"
                  MinWidth="220"
                  Margin="0,6,0,2"
                  IsVisible="{Binding HasMultipleDevices}"
                  ItemsSource="{Binding Devices}"
                  SelectedItem="{Binding SelectedDevice}">
            <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:MainWindowViewModel">
                    <TextBlock Text="{Binding DeviceName}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <Grid Grid.Row="1">
            <ContentControl Name="DeviceLayoutHost" Padding="0" />

            <Button VerticalAlignment="Top" HorizontalAlignment="Right"
                VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                Width="50" Height="50"
                Margin="0,4,63,0"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0">
            <!-- Theme-aware hamburger (three bars) so the menu icon follows Light/Dark
                 instead of being a fixed-white SVG that vanishes on a light window. -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                <Rectangle Width="24" Height="2.5" RadiusX="1.25" RadiusY="1.25" Fill="{DynamicResource AppTextPrimary}" />
                <Rectangle Width="24" Height="2.5" RadiusX="1.25" RadiusY="1.25" Fill="{DynamicResource AppTextPrimary}" />
                <Rectangle Width="24" Height="2.5" RadiusX="1.25" RadiusY="1.25" Fill="{DynamicResource AppTextPrimary}" />
            </StackPanel>
            <Button.Flyout>
                <Flyout Placement="Left">
                    <StackPanel>
                        <Button Width="100" Height="40" VerticalContentAlignment="Center"
                                HorizontalContentAlignment="Center"
                                FontSize="18"
                                Content="Settings"
                                Command="{Binding SelectedDevice.SettingsMenuCommand}" />
                        <Button Width="100" Height="40" VerticalContentAlignment="Center" Margin="0,5,0,0"
                                HorizontalContentAlignment="Center"
                                FontSize="18"
                                Content="Macros"
                                Command="{Binding SelectedDevice.MacroEditorMenuCommand}" />
                        <Separator />
                        <Button Width="100" Height="40" VerticalContentAlignment="Center"
                                HorizontalContentAlignment="Center"
                                FontSize="18"
                                Content="About"
                                Command="{Binding SelectedDevice.AboutMenuCommand}" />
                        <Button Width="100" Height="40" VerticalContentAlignment="Center" Margin="0,5,0,0"
                                HorizontalContentAlignment="Center"
                                FontSize="18"
                                Content="Quit"
                                Command="{Binding SelectedDevice.QuitApplicationCommand}" />
                    </StackPanel>
                </Flyout>
            </Button.Flyout>
            </Button>
        </Grid>
    </Grid>
</Window>
