<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LoupixDeck.ViewModels"
        xmlns:bs="clr-namespace:LoupixDeck.ViewModels.Base"
        xmlns:cnv="clr-namespace:LoupixDeck.Models.Converter"
        xmlns:m="clr-namespace:LoupixDeck.Models"
        x:Class="LoupixDeck.Views.Settings"
        x:DataType="vm:SettingsViewModel"
        x:Name="SettingsWindow"
        mc:Ignorable="d"
        Title="Settings"
        Width="980"
        Height="820">

    <Window.Resources>
        <cnv:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <cnv:ScalingOptionConverter x:Key="ScalingOptionConverter" />
    </Window.Resources>

    <Window.Styles>
        <StyleInclude Source="avares://LoupixDeck/Views/Styles/SettingsStyles.axaml" />
    </Window.Styles>

    <Grid ColumnDefinitions="240,*">

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0" Background="{DynamicResource AppSurfaceLow}" BorderBrush="{DynamicResource AppBorderSubtle}" BorderThickness="0,0,1,0">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="8,12,8,12">

                    <TextBlock Classes="section-header" Text="DEVICE" />
                    <Button Classes="nav" Classes.active="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=General}"
                            Command="{Binding NavigateCommand}" CommandParameter="{x:Static bs:SettingsView.General}">
                        <Grid ColumnDefinitions="6,Auto,*">
                            <Border Grid.Column="0" Classes="nav-accent" />
                            <TextBlock Grid.Column="1" Classes="nav-icon" Text="&#xF2FE;" Margin="6,0,0,0"/>
                            <TextBlock Grid.Column="2" Classes="nav-label" Text="General" />
                        </Grid>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Pages}"
                            Command="{Binding NavigateCommand}" CommandParameter="{x:Static bs:SettingsView.Pages}">
                        <Grid ColumnDefinitions="6,Auto,*">
                            <Border Grid.Column="0" Classes="nav-accent" />
                            <TextBlock Grid.Column="1" Classes="nav-icon" Text="&#xF24A;" Margin="6,0,0,0"/>
                            <TextBlock Grid.Column="2" Classes="nav-label" Text="Pages" />
                        </Grid>
                    </Button>
                    <Button Classes="nav" Classes.active="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Haptic}"
                            Command="{Binding NavigateCommand}" CommandParameter="{x:Static bs:SettingsView.Haptic}">
                        <Grid ColumnDefinitions="6,Auto,*">
                            <Border Grid.Column="0" Classes="nav-accent" />
                            <TextBlock Grid.Column="1" Classes="nav-icon" Text="&#xF566;" Margin="6,0,0,0"/>
                            <TextBlock Grid.Column="2" Classes="nav-label" Text="Feedback" />
                        </Grid>
                    </Button>

                    <TextBlock Classes="section-header" Text="INTEGRATIONS" />
                    <Button Classes="nav" Classes.active="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Plugins}"
                            Command="{Binding NavigateCommand}" CommandParameter="{x:Static bs:SettingsView.Plugins}">
                        <Grid ColumnDefinitions="6,Auto,*">
                            <Border Grid.Column="0" Classes="nav-accent" />
                            <TextBlock Grid.Column="1" Classes="nav-icon" Text="&#xF567;" Margin="6,0,0,0"/>
                            <TextBlock Grid.Column="2" Classes="nav-label" Text="Plugins" />
                        </Grid>
                    </Button>
                    <StackPanel IsVisible="{Binding IsWindows}">
                        <TextBlock Classes="section-header" Text="INPUT" />
                        <Button Classes="nav" Classes.active="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Interception}"
                                Command="{Binding NavigateCommand}" CommandParameter="{x:Static bs:SettingsView.Interception}">
                            <Grid ColumnDefinitions="6,Auto,*">
                                <Border Grid.Column="0" Classes="nav-accent" />
                                <TextBlock Grid.Column="1" Classes="nav-icon" Text="&#xF030C;" Margin="6,0,0,0"/>
                                <TextBlock Grid.Column="2" Classes="nav-label" Text="Macro Driver" />
                            </Grid>
                        </Button>
                    </StackPanel>

                    <StackPanel IsVisible="{Binding IsAppSwitchingSupported}">
                        <TextBlock Classes="section-header" Text="AUTOMATION" />
                        <Button Classes="nav" Classes.active="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=AppSwitching}"
                                Command="{Binding NavigateCommand}" CommandParameter="{x:Static bs:SettingsView.AppSwitching}">
                            <Grid ColumnDefinitions="6,Auto,*">
                                <Border Grid.Column="0" Classes="nav-accent" />
                                <TextBlock Grid.Column="1" Classes="nav-icon" Text="&#xF05DF;" Margin="6,0,0,0"/>
                                <TextBlock Grid.Column="2" Classes="nav-label" Text="App Switching" />
                            </Grid>
                        </Button>
                    </StackPanel>

                    <TextBlock Classes="section-header" Text="APPEARANCE" />
                    <Button Classes="nav" Classes.active="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Theme}"
                            Command="{Binding NavigateCommand}" CommandParameter="{x:Static bs:SettingsView.Theme}">
                        <Grid ColumnDefinitions="6,Auto,*">
                            <Border Grid.Column="0" Classes="nav-accent" />
                            <TextBlock Grid.Column="1" Classes="nav-icon" Text="&#xF50E;" Margin="6,0,0,0"/>
                            <TextBlock Grid.Column="2" Classes="nav-label" Text="Theme" />
                        </Grid>
                    </Button>

                    <TextBlock Classes="section-header" Text="APP" />
                    <Button Classes="nav" Classes.active="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=About}"
                            Command="{Binding NavigateCommand}" CommandParameter="{x:Static bs:SettingsView.About}">
                        <Grid ColumnDefinitions="6,Auto,*">
                            <Border Grid.Column="0" Classes="nav-accent" />
                            <TextBlock Grid.Column="1" Classes="nav-icon" Text="&#xF02D;" Margin="6,0,0,0"/>
                            <TextBlock Grid.Column="2" Classes="nav-label" Text="About" />
                        </Grid>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ===== Right pane ===== -->
        <ScrollViewer Grid.Column="1" Padding="24,16,4,16" HorizontalScrollBarVisibility="Disabled">
            <Grid>

                <!-- ====== General ====== -->
                <StackPanel IsVisible="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=General}">
                    <TextBlock Classes="page-title" Text="General" />

                    <!-- Device card -->
                    <Border Classes="card">
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                <TextBlock FontFamily="{StaticResource MdiFont}" Text="&#xF2FE;" FontSize="24" VerticalAlignment="Center"/>
                                <TextBlock Classes="card-title" Text="{Binding DeviceName}" Margin="0,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Row="0" Grid.Column="1" Classes="pill"
                                    Classes.ok="{Binding DeviceConnected}"
                                    Classes.error="{Binding !DeviceConnected}">
                                <TextBlock Text="{Binding DeviceStatusText}" />
                            </Border>

                            <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,16,0,0">
                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Port" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Classes="value" Text="{Binding Config.DevicePort}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Baudrate" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Classes="value" Text="{Binding Config.DeviceBaudrate}" Margin="0,8,0,0"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Firmware" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Classes="value" Text="{Binding DeviceVersion}" Margin="0,8,0,0"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Serial" Margin="0,8,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Classes="value" Text="{Binding DeviceSerial}" Margin="0,8,0,0"/>

                                <Button Grid.Row="4" Grid.ColumnSpan="2" Content="Reconnect"
                                        Command="{Binding ReconnectDeviceCommand}"
                                        HorizontalAlignment="Left" Margin="0,16,0,0"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Display card -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="card-title" Text="Display" />
                            <TextBlock Classes="label" Text="Brightness" />
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,6,0,0">
                                <TextBlock FontFamily="{StaticResource MdiFont}" Text="&#xF1A4;" FontSize="16" VerticalAlignment="Center" Foreground="{DynamicResource AppTextSecondary}"/>
                                <Slider Minimum="0" Maximum="100" Width="320" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding Config.Brightness, Mode=TwoWay}" />
                                <TextBlock FontFamily="{StaticResource MdiFont}" Text="&#xF59C;" FontSize="20" VerticalAlignment="Center"/>
                                <TextBlock Classes="value" Text="{Binding Config.Brightness}" VerticalAlignment="Center" Width="36" TextAlignment="Right"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Behavior card -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="card-title" Text="Behavior" />
                            <TextBlock Classes="label" Text="Startup touch page" />
                            <ComboBox Width="200" Margin="0,6,0,0"
                                      ItemsSource="{Binding TouchPages}"
                                      SelectedIndex="{Binding Config.StartupTouchPageIndex, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="m:TouchButtonPage">
                                        <TextBlock Text="{Binding PageName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Classes="hint" Margin="0,6,0,0"
                                       Text="Applied on next app launch." />
                        </StackPanel>
                    </Border>

                    <!-- Window card -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="card-title" Text="Window" />
                            <TextBlock Classes="label" Text="Close button behavior" />
                            <RadioButton GroupName="closeBehavior" Content="Minimize to tray"
                                         HorizontalAlignment="Left" Margin="0,6,0,0"
                                         IsChecked="{Binding Config.CloseButtonBehavior, Mode=TwoWay,
                                                     Converter={StaticResource EnumToBooleanConverter},
                                                     ConverterParameter={x:Static m:CloseButtonBehavior.MinimizeToTray}}" />
                            <RadioButton GroupName="closeBehavior" Content="Quit application"
                                         HorizontalAlignment="Left" Margin="0,4,0,0"
                                         IsChecked="{Binding Config.CloseButtonBehavior, Mode=TwoWay,
                                                     Converter={StaticResource EnumToBooleanConverter},
                                                     ConverterParameter={x:Static m:CloseButtonBehavior.Quit}}" />
                            <TextBlock Classes="hint" Margin="0,6,0,0"
                                       Text="Choose 'Quit' on desktops without a system tray." />
                            <CheckBox Content="Start minimized to tray"
                                      HorizontalAlignment="Left" Margin="0,10,0,0"
                                      IsChecked="{Binding Config.StartMinimizedToTray, Mode=TwoWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====== Pages ====== -->
                <StackPanel IsVisible="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Pages}">
                    <TextBlock Classes="page-title" Text="Pages" />

                    <Grid ColumnDefinitions="*,12,*">
                        <Border Grid.Column="0" Classes="card" Margin="0,0,0,12">
                            <StackPanel>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="card-title" Text="Touch pages" />
                                    <Button Grid.Column="1" Content="+ Add" Command="{Binding AddTouchPageCommand}" />
                                </Grid>
                                <ItemsControl ItemsSource="{Binding TouchPages}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="m:TouchButtonPage">
                                            <Border Background="{DynamicResource AppSurfaceAlt}" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                                <Grid ColumnDefinitions="80,*,Auto,Auto,Auto,Auto,Auto">
                                                    <Border Grid.Column="0" BorderBrush="{DynamicResource AppBorderSubtle}" BorderThickness="1" CornerRadius="3" Height="40">
                                                        <Image Source="{Binding Wallpaper, Converter={StaticResource SkiaToBitmapConverter}}" Stretch="UniformToFill" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding PageName}" VerticalAlignment="Center" Margin="10,0,0,0" />
                                                    <Button Grid.Column="2" Classes="row-action" ToolTip.Tip="Edit wallpaper"
                                                            Command="{Binding $parent[Window].DataContext.EditWallpaperCommand}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock FontFamily="{StaticResource MdiFont}" Text="&#xF02E9;" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                    </Button>
                                                    <Button Grid.Column="3" Classes="row-action" ToolTip.Tip="Edit page commands"
                                                            Command="{Binding $parent[Window].DataContext.EditPageCommandsCommand}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock FontFamily="{StaticResource MdiFont}" Text="&#xF18D8;" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                    </Button>
                                                    <Button Grid.Column="4" Classes="row-action" Content="↑" ToolTip.Tip="Move up"
                                                            Command="{Binding $parent[Window].DataContext.MoveTouchPageUpCommand}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Grid.Column="5" Classes="row-action" Content="↓" ToolTip.Tip="Move down"
                                                            Command="{Binding $parent[Window].DataContext.MoveTouchPageDownCommand}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Grid.Column="6" Classes="row-action danger" Content="✕" ToolTip.Tip="Remove page"
                                                            Command="{Binding $parent[Window].DataContext.RemoveTouchPageCommand}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Classes="card">
                            <StackPanel>
                                <!-- Single shared list — devices without side strips (Live S). -->
                                <StackPanel IsVisible="{Binding !HasIndependentRotarySides}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="card-title" Text="Rotary pages" />
                                        <Button Grid.Column="1" Content="+ Add" Command="{Binding AddRotaryPageCommand}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding RotaryPages}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="m:RotaryButtonPage">
                                                <Border Background="{DynamicResource AppSurfaceAlt}" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                                                        <TextBlock Grid.Column="0" Text="{Binding PageName}" VerticalAlignment="Center" />
                                                        <Button Grid.Column="1" Classes="row-action" ToolTip.Tip="Edit page commands"
                                                                Command="{Binding $parent[Window].DataContext.EditPageCommandsCommand}"
                                                                CommandParameter="{Binding}">
                                                            <TextBlock FontFamily="{StaticResource MdiFont}" Text="&#xF18D8;" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                        </Button>
                                                        <Button Grid.Column="2" Classes="row-action" Content="↑" ToolTip.Tip="Move up"
                                                                Command="{Binding $parent[Window].DataContext.MoveRotaryPageUpCommand}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Grid.Column="3" Classes="row-action" Content="↓" ToolTip.Tip="Move down"
                                                                Command="{Binding $parent[Window].DataContext.MoveRotaryPageDownCommand}"
                                                                CommandParameter="{Binding}" />
                                                        <Button Grid.Column="4" Classes="row-action danger" Content="✕" ToolTip.Tip="Remove rotary page"
                                                                Command="{Binding $parent[Window].DataContext.RemoveRotaryPageCommand}"
                                                                CommandParameter="{Binding}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Independent left/right lists — devices with side strips (Razer). -->
                                <StackPanel IsVisible="{Binding HasIndependentRotarySides}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Classes="card-title" Text="Left rotary pages" />
                                        <Button Grid.Column="1" Content="+ Add" Command="{Binding AddLeftRotaryPageCommand}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding LeftRotaryPages}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="m:RotaryButtonPage">
                                                <Border Background="{DynamicResource AppSurfaceAlt}" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                                        <TextBlock Grid.Column="0" Text="{Binding PageName}" VerticalAlignment="Center" />
                                                        <Button Grid.Column="1" Classes="row-action" ToolTip.Tip="Edit page commands"
                                                                Command="{Binding $parent[Window].DataContext.EditPageCommandsCommand}"
                                                                CommandParameter="{Binding}">
                                                            <TextBlock FontFamily="{StaticResource MdiFont}" Text="&#xF18D8;" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                        </Button>
                                                        <Button Grid.Column="2" Classes="row-action danger" Content="✕" ToolTip.Tip="Remove rotary page"
                                                                Command="{Binding $parent[Window].DataContext.RemoveLeftRotaryPageCommand}"
                                                                CommandParameter="{Binding}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid ColumnDefinitions="*,Auto" Margin="0,12,0,0">
                                        <TextBlock Grid.Column="0" Classes="card-title" Text="Right rotary pages" />
                                        <Button Grid.Column="1" Content="+ Add" Command="{Binding AddRightRotaryPageCommand}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding RightRotaryPages}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="m:RotaryButtonPage">
                                                <Border Background="{DynamicResource AppSurfaceAlt}" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                                        <TextBlock Grid.Column="0" Text="{Binding PageName}" VerticalAlignment="Center" />
                                                        <Button Grid.Column="1" Classes="row-action" ToolTip.Tip="Edit page commands"
                                                                Command="{Binding $parent[Window].DataContext.EditPageCommandsCommand}"
                                                                CommandParameter="{Binding}">
                                                            <TextBlock FontFamily="{StaticResource MdiFont}" Text="&#xF18D8;" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                        </Button>
                                                        <Button Grid.Column="2" Classes="row-action danger" Content="✕" ToolTip.Tip="Remove rotary page"
                                                                Command="{Binding $parent[Window].DataContext.RemoveRightRotaryPageCommand}"
                                                                CommandParameter="{Binding}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="card-title" Text="Page switching" />
                            <CheckBox Content="Show page name overlay when switching pages"
                                      IsChecked="{Binding Config.ShowPageNameOverlayEnabled, Mode=TwoWay}"
                                      ToolTip.Tip="Briefly displays the new page name on the first touch button (~2s) after switching touch or rotary pages." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====== Feedback (touch flash + haptic) ====== -->
                <StackPanel IsVisible="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Haptic}">
                    <TextBlock Classes="page-title" Text="Feedback" />

                    <!-- Touch flash overlay (top) -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="card-title" Text="Touch flash" />
                            <CheckBox Content="Flash touch buttons on press"
                                      IsChecked="{Binding Config.TouchFeedbackEnabled, Mode=TwoWay}" />
                            <Grid ColumnDefinitions="80,Auto,*,40" RowDefinitions="Auto,Auto" RowSpacing="8" Margin="0,8,0,0"
                                  IsEnabled="{Binding Config.TouchFeedbackEnabled}">
                                <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Color" VerticalAlignment="Center" />
                                <ColorPicker Grid.Row="0" Grid.Column="1" Width="120" HorizontalAlignment="Left"
                                             Color="{Binding Config.TouchFeedbackColor, Mode=TwoWay}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Opacity" VerticalAlignment="Center" />
                                <Slider Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Minimum="0" Maximum="1"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                                        Value="{Binding Config.TouchFeedbackOpacity, Mode=TwoWay}" />
                                <TextBlock Grid.Row="1" Grid.Column="3" Classes="value"
                                           Text="{Binding Config.TouchFeedbackOpacity, StringFormat='{}{0:F2}'}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Touch sliding prevention + diagnostic logging -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="card-title" Text="Touch input" />
                            <CheckBox Content="Prevent multi-trigger while finger is down"
                                      IsChecked="{Binding Config.TouchSlidingPreventionEnabled, Mode=TwoWay}"
                                      ToolTip.Tip="Ignores additional TOUCH_START events until the finger is lifted. Defends against duplicate triggers when sliding across buttons or tapping near a button boundary." />
                        </StackPanel>
                    </Border>

                    <!-- Haptic (enable + both effects in one card) -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="card-title" Text="Haptic" />
                            <CheckBox Content="Enable haptic feedback"
                                      IsChecked="{Binding Config.HapticEnabled, Mode=TwoWay}" />

                            <StackPanel IsEnabled="{Binding Config.HapticEnabled}">
                                <!-- First effect -->
                                <TextBlock Text="First effect (immediate)" FontWeight="SemiBold" Margin="0,16,0,4" />
                                <Grid DataContext="{Binding FirstHapticStep}"
                                      ColumnDefinitions="100,*" RowDefinitions="Auto,Auto" Margin="0,4,0,0">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Effect" VerticalAlignment="Center" />
                                    <ComboBox Grid.Row="0" Grid.Column="1" Width="260" HorizontalAlignment="Left"
                                              ItemsSource="{Binding $parent[Window].DataContext.VibrationPatterns}"
                                              SelectedItem="{Binding SelectedEffectItem, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="cnv:VibrationPatternItem">
                                                <TextBlock Text="{Binding Name}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Duration" VerticalAlignment="Center" Margin="0,12,0,0" />
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
                                        <Slider Minimum="2" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Value="{Binding Duration, Mode=TwoWay}" Width="300" />
                                        <TextBlock Text="{Binding Duration}" VerticalAlignment="Center" Width="40" />
                                    </StackPanel>
                                </Grid>

                                <!-- Add-second-effect button -->
                                <Button Content="Add second effect" Command="{Binding AddHapticStepCommand}"
                                        HorizontalAlignment="Left" Margin="0,14,0,0"
                                        IsVisible="{Binding CanAddHapticStep}" />

                                <!-- Second effect (conditional) -->
                                <StackPanel IsVisible="{Binding HasSecondHapticStep}">
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,16,0,4">
                                        <TextBlock Grid.Column="0" Text="Second effect (after delay)" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="Remove"
                                                Command="{Binding RemoveHapticStepCommand}"
                                                CommandParameter="{Binding SecondHapticStep}" />
                                    </Grid>
                                    <Grid DataContext="{Binding SecondHapticStep}"
                                          ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto" Margin="0,4,0,0">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Effect" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="0" Grid.Column="1" Width="260" HorizontalAlignment="Left"
                                                  ItemsSource="{Binding $parent[Window].DataContext.VibrationPatterns}"
                                                  SelectedItem="{Binding SelectedEffectItem, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="cnv:VibrationPatternItem">
                                                    <TextBlock Text="{Binding Name}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Delay" VerticalAlignment="Center" Margin="0,12,0,0" />
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
                                            <Slider Minimum="4" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding Delay, Mode=TwoWay}" Width="300" />
                                            <TextBlock Text="{Binding Delay}" VerticalAlignment="Center" Width="40" />
                                        </StackPanel>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Duration" VerticalAlignment="Center" Margin="0,12,0,0" />
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
                                            <Slider Minimum="2" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True"
                                                    Value="{Binding Duration, Mode=TwoWay}" Width="300" />
                                            <TextBlock Text="{Binding Duration}" VerticalAlignment="Center" Width="40" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====== Plugins ====== -->
                <StackPanel IsVisible="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Plugins}">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="page-title" Text="Plugins" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                    VerticalAlignment="Center">
                            <Button Content="Install from Zip…" Click="OnInstallPluginClick" />
                            <Button Content="Remove" Click="OnRemovePluginClick" />
                            <Button Content="Open Plugins Folder"
                                    Command="{Binding OpenPluginsFolderCommand}" />
                        </StackPanel>
                    </Grid>

                    <Border Classes="card">
                        <Grid ColumnDefinitions="220,*" MinHeight="280">
                            <ListBox x:Name="PluginList" Grid.Column="0" Margin="0,0,12,0"
                                     SelectionChanged="OnPluginSelectionChanged" />
                            <ScrollViewer Grid.Column="1">
                                <StackPanel x:Name="PluginSettingsHost" Spacing="8" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="PluginActionStatus" Classes="hint" Margin="0,8,0,0"
                               IsVisible="False" TextWrapping="Wrap" />

                    <TextBlock x:Name="PluginRestartHint" Classes="hint" Margin="0,8,0,0"
                               IsVisible="False"
                               Text="Some changes finish applying after the app is restarted." />
                </StackPanel>

                <!-- ====== Interception ====== -->
                <StackPanel IsVisible="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Interception}">
                    <TextBlock Classes="page-title" Text="Macro Driver" />

                    <!-- Status card -->
                    <Border Classes="card">
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                <TextBlock FontFamily="{StaticResource MdiFont}" Text="&#xF030C;" FontSize="24" VerticalAlignment="Center"/>
                                <TextBlock Classes="card-title" Text="Interception Driver" Margin="0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Row="0" Grid.Column="1" Classes="pill"
                                    Classes.ok="{Binding InterceptionDriverInstalled}"
                                    Classes.error="{Binding !InterceptionDriverInstalled}">
                                <TextBlock Text="{Binding InterceptionStatusText}" />
                            </Border>

                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Classes="hint" Margin="0,12,0,0"
                                       Text="The Interception kernel driver lets keyboard and mouse macros reach apps that read raw input (games / anti-cheat), which the default SendInput method cannot. The driver is downloaded from the official GitHub release and is not bundled. Installing or removing it requires a reboot." />
                        </Grid>
                    </Border>

                    <!-- Toggle card -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="card-title" Text="Usage" />
                            <CheckBox Content="Use Interception for keyboard and mouse macros"
                                      IsEnabled="{Binding InterceptionDriverInstalled}"
                                      IsChecked="{Binding InterceptionEnabled, Mode=TwoWay}" />
                            <TextBlock Classes="hint" Margin="0,6,0,0"
                                       Text="When off (or when the driver is not installed), macros fall back to SendInput. Takes effect immediately." />
                        </StackPanel>
                    </Border>

                    <!-- Install / Uninstall card -->
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="card-title" Text="Driver" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Content="Download &amp; Install"
                                        Command="{Binding InstallInterceptionCommand}"
                                        IsEnabled="{Binding !InterceptionBusy}" />
                                <Button Content="Uninstall" Classes="danger"
                                        Command="{Binding UninstallInterceptionCommand}"
                                        IsEnabled="{Binding !InterceptionBusy}" />
                            </StackPanel>
                            <TextBlock Classes="hint" Margin="0,10,0,0"
                                       Text="The Interception driver is third-party software by Francisco Lopes (github.com/oblitum/Interception). It is free for non-commercial use only — commercial use requires a separate license from its author." />
                            <TextBlock Classes="hint" Margin="0,10,0,0"
                                       Text="{Binding InterceptionStatusMessage}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====== Theme ====== -->
                <StackPanel IsVisible="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Theme}">
                    <TextBlock Classes="page-title" Text="Theme" />
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="card-title" Text="Appearance" />
                            <RadioButton Content="Dark"   GroupName="theme" IsChecked="{Binding ThemeIsDark, Mode=TwoWay}" Margin="0,4,0,0"/>
                            <RadioButton Content="Light"  GroupName="theme" IsChecked="{Binding ThemeIsLight, Mode=TwoWay}" Margin="0,4,0,0"/>
                            <RadioButton Content="System" GroupName="theme" IsChecked="{Binding ThemeIsSystem, Mode=TwoWay}" Margin="0,4,0,0"/>
                            <TextBlock Classes="hint" Margin="0,8,0,0"
                                       Text="Applies immediately. Some controls keep the previous palette until next app launch." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====== About ====== -->
                <StackPanel IsVisible="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=About}">
                    <TextBlock Classes="page-title" Text="About" />
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Text="LoupixDeck" FontSize="20" FontWeight="Bold" />
                            <TextBlock Classes="label" Text="{Binding Version}" Margin="0,4,0,0"/>
                            <TextBlock Classes="hint" Margin="0,12,0,0"
                                       Text="Open-source Avalonia desktop app controlling the Loupedeck Live S on Linux and Windows." />
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,16,0,0">
                                <Button Content="Project Website" Command="{Binding OpenWebsiteCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====== App Switching ====== -->
                <StackPanel IsVisible="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=AppSwitching}">
                    <TextBlock Classes="page-title" Text="App Switching" />

                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="card-title" Text="Automatic page switching" />
                            <CheckBox Content="Switch pages based on the focused application"
                                      IsChecked="{Binding Config.AppSwitchingEnabled, Mode=TwoWay}" Margin="0,4,0,0" />
                            <TextBlock Classes="hint" Margin="0,6,0,0"
                                       Text="When the foreground window changes, the deck switches to the page bound by the first matching rule. Process name is matched case-insensitively (a trailing &quot;.exe&quot; is ignored). On Linux this requires an X11 / XWayland session and the 'xprop' tool." />

                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0" VerticalAlignment="Center">
                                <TextBlock Classes="label" Text="No-match fallback page" VerticalAlignment="Center" />
                                <ComboBox Width="160"
                                          ItemsSource="{Binding FallbackPageOptions}"
                                          SelectedIndex="{Binding FallbackSelectionIndex, Mode=TwoWay}" />
                            </StackPanel>
                            <TextBlock Classes="hint" Margin="0,6,0,0"
                                       Text="When no rule matches the focused app, switch to this touch page. '(do nothing)' keeps the current page." />
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Classes="card-title" Text="Rules" />
                                <Button Grid.Column="1" Content="+ Add rule" Command="{Binding AddAppBindingCommand}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*,120,120,40" Margin="0,8,0,4">
                                <TextBlock Grid.Column="0" Classes="label" Text="Process" />
                                <TextBlock Grid.Column="1" Classes="label" Text="Title contains" Margin="8,0,0,0" />
                                <TextBlock Grid.Column="2" Classes="label" Text="Touch page" Margin="8,0,0,0" />
                                <TextBlock Grid.Column="3" Classes="label" Text="Rotary page" Margin="8,0,0,0" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding AppBindingRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:AppBindingRow">
                                        <Border Background="{DynamicResource AppSurfaceAlt}" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="*,*,120,120,40">
                                                <TextBox Grid.Column="0" PlaceholderText="chrome"
                                                         Text="{Binding Binding.ProcessName, Mode=TwoWay}" />
                                                <TextBox Grid.Column="1" PlaceholderText="(optional)" Margin="8,0,0,0"
                                                         Text="{Binding Binding.TitleContains, Mode=TwoWay}" />
                                                <ComboBox Grid.Column="2" Margin="8,0,0,0" HorizontalAlignment="Stretch"
                                                          ItemsSource="{Binding TouchPages}"
                                                          SelectedIndex="{Binding Binding.TouchPageIndex, Mode=TwoWay}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate DataType="m:TouchButtonPage">
                                                            <TextBlock Text="{Binding PageName}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <ComboBox Grid.Column="3" Margin="8,0,0,0" HorizontalAlignment="Stretch"
                                                          ItemsSource="{Binding RotaryPageOptions}"
                                                          SelectedIndex="{Binding Binding.RotarySelectionIndex, Mode=TwoWay}" />
                                                <Button Grid.Column="4" Classes="row-action danger" Content="✕" ToolTip.Tip="Remove rule"
                                                        Command="{Binding $parent[Window].DataContext.RemoveAppBindingCommand}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Classes="hint" Margin="0,6,0,0"
                                       Text="Rules are evaluated top to bottom — the first match wins. &quot;Rotary page&quot; is optional: '(unchanged)' leaves the current rotary page as-is." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

    </Grid>
</Window>
