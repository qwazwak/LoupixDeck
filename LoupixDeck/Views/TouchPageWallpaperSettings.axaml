<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LoupixDeck.ViewModels"
        x:Class="LoupixDeck.Views.TouchPageWallpaperSettings"
        x:DataType="vm:TouchPageWallpaperSettingsViewModel"
        mc:Ignorable="d"
        Title="Edit Wallpaper"
        Width="940"
        Height="700"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Window.Styles>
        <StyleInclude Source="avares://LoupixDeck/Views/Styles/SettingsStyles.axaml" />

        <!-- Clickable device-preview region. -->
        <Style Selector="Button.region">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceAlt}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.region.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccent}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
    </Window.Styles>

    <Grid Margin="16" RowDefinitions="Auto,*,Auto" RowSpacing="12">

        <TextBlock Grid.Row="0"
                   Classes="card-title"
                   Margin="0"
                   Text="{Binding PageName}" />

        <Grid Grid.Row="1" ColumnDefinitions="Auto,16,*">

            <!-- ░░░ Left: device preview ░░░ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    VerticalAlignment="Top">
                <StackPanel Spacing="10">
                    <TextBlock Classes="label" Text="Device preview" HorizontalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                HorizontalAlignment="Center" VerticalAlignment="Center">

                        <!-- Left side display -->
                        <StackPanel Spacing="4" IsVisible="{Binding HasSideStrips}">
                            <Button Classes="region" Classes.selected="{Binding IsLeftSelected}"
                                    Command="{Binding SelectLeftCommand}"
                                    Width="44" Height="200">
                                <Image Source="{Binding LeftPreview, Converter={StaticResource SkiaToBitmapConverter}}"
                                       Stretch="Fill" />
                            </Button>
                            <TextBlock Classes="label" Text="Left" FontSize="11" HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Main wallpaper -->
                        <StackPanel Spacing="4">
                            <Button Classes="region" Classes.selected="{Binding IsMainSelected}"
                                    Command="{Binding SelectMainCommand}"
                                    Width="356" Height="200">
                                <Image Source="{Binding MainPreview, Converter={StaticResource SkiaToBitmapConverter}}"
                                       Stretch="Uniform" />
                            </Button>
                            <TextBlock Classes="label" Text="Main" FontSize="11" HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Right side display -->
                        <StackPanel Spacing="4" IsVisible="{Binding HasSideStrips}">
                            <Button Classes="region" Classes.selected="{Binding IsRightSelected}"
                                    Command="{Binding SelectRightCommand}"
                                    Width="44" Height="200">
                                <Image Source="{Binding RightPreview, Converter={StaticResource SkiaToBitmapConverter}}"
                                       Stretch="Fill" />
                            </Button>
                            <TextBlock Classes="label" Text="Right" FontSize="11" HorizontalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ░░░ Right: settings for the active target ░░░ -->
            <Border Grid.Column="2"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="10">

                    <TextBlock Classes="card-title" Margin="0" Text="{Binding ActiveTargetTitle}" />
                    <TextBlock Classes="label" Text="{Binding ActiveTargetSizeInfo}" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border BorderBrush="{DynamicResource AppBorderSubtle}" BorderThickness="1" CornerRadius="3">
                            <Image Width="220" Height="124"
                                   Source="{Binding ActivePreview, Converter={StaticResource SkiaToBitmapConverter}}" />
                        </Border>
                        <StackPanel Spacing="6" VerticalAlignment="Center">
                            <Button Content="Select…" Command="{Binding SelectImageCommand}" Width="110" />
                            <Button Content="Remove"  Command="{Binding RemoveCommand}" Width="110"
                                    IsEnabled="{Binding HasActiveImage}" />
                        </StackPanel>
                    </StackPanel>

                    <Grid ColumnDefinitions="80,*,40" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6">

                        <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Opacity"    VerticalAlignment="Center" />
                        <Slider    Grid.Row="0" Grid.Column="1" Minimum="0"  Maximum="1"
                                   TickFrequency="0.1" IsSnapToTickEnabled="True"
                                   Value="{Binding WallpaperOpacity, Mode=TwoWay}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Scaling"    VerticalAlignment="Center" />
                        <ComboBox  Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch"
                                   ItemsSource="{Binding WallpaperScalingOptions}"
                                   SelectedItem="{Binding SelectedWallpaperScalingOption, Mode=TwoWay}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Scale"      VerticalAlignment="Center" />
                        <Slider    Grid.Row="2" Grid.Column="1" Minimum="1"  Maximum="400"
                                   TickFrequency="1" IsSnapToTickEnabled="True"
                                   Value="{Binding WallpaperScaling, Mode=TwoWay}" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Classes="value" Text="{Binding WallpaperScaling}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Position X" VerticalAlignment="Center" />
                        <Slider    Grid.Row="3" Grid.Column="1" Minimum="-480" Maximum="480"
                                   TickFrequency="1" IsSnapToTickEnabled="True"
                                   Value="{Binding WallpaperPositionX, Mode=TwoWay}" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Classes="value" Text="{Binding WallpaperPositionX}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="Position Y" VerticalAlignment="Center" />
                        <Slider    Grid.Row="4" Grid.Column="1" Minimum="-270" Maximum="270"
                                   TickFrequency="1" IsSnapToTickEnabled="True"
                                   Value="{Binding WallpaperPositionY, Mode=TwoWay}" />
                        <TextBlock Grid.Row="4" Grid.Column="2" Classes="value" Text="{Binding WallpaperPositionY}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Classes="label" Text="Mirror"     VerticalAlignment="Center" />
                        <CheckBox  Grid.Row="5" Grid.Column="1" Content="Flip horizontally"
                                   IsChecked="{Binding WallpaperMirror, Mode=TwoWay}" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Reset" Command="{Binding ResetCommand}" />
                        <Button Content="Mirror to other side"
                                Command="{Binding MirrorToOtherSideCommand}"
                                IsEnabled="{Binding IsSideSelected}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Width="100" Command="{Binding CancelCommand}" />
            <Button Content="OK"     Width="100" IsDefault="True" Command="{Binding ConfirmCommand}" />
        </StackPanel>
    </Grid>
</Window>
