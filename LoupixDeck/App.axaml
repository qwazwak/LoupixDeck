<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LoupixDeck.App"
             xmlns:local="using:LoupixDeck"
             xmlns:converter="using:LoupixDeck.Models.Converter"
             RequestedThemeVariant="Dark">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
        <!-- App-chrome surfaces resolve through theme-aware brushes so the whole UI
             follows Light/Dark. The simulated device (Views/Devices/*) intentionally
             stays dark regardless of theme — it represents black hardware. -->
        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource AppWindowBackground}" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource AppControlBackground}" />
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundHover}" />
        </Style>
        <Style Selector="TextBox:focus /template/ Border">
            <Setter Property="Background" Value="{DynamicResource AppControlBackground}" />
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="{DynamicResource AppControlBackground}" />
        </Style>
        <Style Selector="NumericUpDown:pointerover /template/ Border">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundHover}" />
        </Style>
        <Style Selector="NumericUpDown:focus /template/ Border">
            <Setter Property="Background" Value="{DynamicResource AppControlBackground}" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <!-- ===== Theme-aware app-chrome palette =====
                 Neutral surfaces/borders/text for the application UI (windows,
                 settings, dialogs, pagers, macro editor). Accent (blue) and status
                 colours (red/green) are intentionally theme-invariant literals — they
                 read fine on both Light and Dark. The simulated-device chrome (touch
                 frame/body/screen) follows the theme via the Device* brushes in each
                 theme dictionary; the LED/knob plastic is rendered theme-aware in
                 BitmapHelper. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppWindowBackground" Color="#1E1E1E" />
                    <SolidColorBrush x:Key="AppSurfaceLow" Color="#1A1A1A" />
                    <SolidColorBrush x:Key="AppSurface" Color="#262626" />
                    <SolidColorBrush x:Key="AppSurfaceAlt" Color="#2D2D2D" />
                    <SolidColorBrush x:Key="AppControlBackground" Color="#3A3A3A" />
                    <SolidColorBrush x:Key="AppControlBackgroundHover" Color="#4A4A4A" />
                    <SolidColorBrush x:Key="AppControlBackgroundActive" Color="#373737" />
                    <SolidColorBrush x:Key="AppBorderSubtle" Color="#3A3A3A" />
                    <!-- Touch-button editor canvas: deliberately lighter than the app
                         surfaces so a black button stays clearly visible. -->
                    <SolidColorBrush x:Key="AppEditorCanvasBackground" Color="#3E4146" />
                    <!-- Subtle accent tint behind an active/selected slot (pairs with the
                         theme-invariant blue accent border). -->
                    <SolidColorBrush x:Key="AppAccentSubtle" Color="#1F2A3A" />
                    <SolidColorBrush x:Key="AppTextPrimary" Color="#E4E4E4" />
                    <SolidColorBrush x:Key="AppTextSecondary" Color="#9A9A9A" />
                    <SolidColorBrush x:Key="AppTextMuted" Color="#707070" />
                    <!-- Simulated-device chrome (the dark hardware in Dark mode). -->
                    <SolidColorBrush x:Key="DeviceScreenBackground" Color="#0F0F0F" />
                    <SolidColorBrush x:Key="DeviceButtonBorder" Color="#5A5A5A" />
                    <SolidColorBrush x:Key="DeviceBodyBrush" Color="#121212" />
                    <!-- Screen bezel/recess + seam frame around the touch grid. -->
                    <LinearGradientBrush x:Key="DeviceBezelBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Offset="0" Color="#101114" />
                        <GradientStop Offset="1" Color="#16181d" />
                    </LinearGradientBrush>
                    <!-- Baked body artwork chosen per theme (see tools/BodyTextureBaker). -->
                    <x:String x:Key="DeviceBodySvgPath">avares://LoupixDeck/Assets/loupedeck-gehaeuse.svg</x:String>
                    <x:String x:Key="RazerBodySvgPath">avares://LoupixDeck/Assets/razer-gehaeuse.svg</x:String>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppWindowBackground" Color="#F3F3F3" />
                    <SolidColorBrush x:Key="AppSurfaceLow" Color="#E9E9E9" />
                    <SolidColorBrush x:Key="AppSurface" Color="#FBFBFB" />
                    <SolidColorBrush x:Key="AppSurfaceAlt" Color="#F0F0F0" />
                    <SolidColorBrush x:Key="AppControlBackground" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="AppControlBackgroundHover" Color="#ECECEC" />
                    <SolidColorBrush x:Key="AppControlBackgroundActive" Color="#DCDCDC" />
                    <SolidColorBrush x:Key="AppBorderSubtle" Color="#CFCFCF" />
                    <!-- Touch-button editor canvas: deliberately lighter than the app
                         surfaces so a black button stays clearly visible. -->
                    <SolidColorBrush x:Key="AppEditorCanvasBackground" Color="#DCDEE2" />
                    <!-- Subtle accent tint behind an active/selected slot (pairs with the
                         theme-invariant blue accent border). -->
                    <SolidColorBrush x:Key="AppAccentSubtle" Color="#D6E8FB" />
                    <SolidColorBrush x:Key="AppTextPrimary" Color="#1C1C1C" />
                    <SolidColorBrush x:Key="AppTextSecondary" Color="#5C5C5C" />
                    <SolidColorBrush x:Key="AppTextMuted" Color="#8A8A8A" />
                    <!-- Simulated-device chrome rendered as light hardware in Light mode. -->
                    <SolidColorBrush x:Key="DeviceScreenBackground" Color="#C8C8C8" />
                    <SolidColorBrush x:Key="DeviceButtonBorder" Color="#A8A8A8" />
                    <SolidColorBrush x:Key="DeviceBodyBrush" Color="#D6D6D6" />
                    <!-- Screen bezel/recess + seam frame, rendered as a light recessed frame. -->
                    <LinearGradientBrush x:Key="DeviceBezelBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Offset="0" Color="#C2C2C2" />
                        <GradientStop Offset="1" Color="#B0B0B0" />
                    </LinearGradientBrush>
                    <!-- Baked body artwork chosen per theme (see tools/BodyTextureBaker). -->
                    <x:String x:Key="DeviceBodySvgPath">avares://LoupixDeck/Assets/loupedeck-gehaeuse-light.svg</x:String>
                    <x:String x:Key="RazerBodySvgPath">avares://LoupixDeck/Assets/razer-gehaeuse-light.svg</x:String>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <converter:SKBitmapToAvaloniaBitmapConverter x:Key="SkiaToBitmapConverter" />
            <converter:BoolToBrushConverter x:Key="BoolToBrushConverter" />
            <FontFamily x:Key="MdiFont">avares://LoupixDeck/Assets/Fonts/materialdesignicons-webfont.ttf#Material Design Icons</FontFamily>

            <!-- Device-chrome accents (theme-invariant): mark selected/unselected
                 simulated device buttons. -->
            <SolidColorBrush x:Key="UnselectedBrush" Color="#FF4b4b4b" />
            <SolidColorBrush x:Key="SelectedBrush" Color="#FF373737" />

            <!-- Accent used to mark the active page chip in the page toolbar. A clear,
                 saturated blue so the current page reads at a glance. Theme-invariant. -->
            <SolidColorBrush x:Key="PageActiveBrush" Color="#FF2F7DD1" />
            <SolidColorBrush x:Key="PageActiveBorderBrush" Color="#FF3D9BFF" />
            <SolidColorBrush x:Key="PageChipBorderBrush" Color="#FF454545" />

            <DropShadowEffect x:Key="InnerShadow"
                              Color="#77000000"
                              BlurRadius="8"
                              OffsetX="0"
                              OffsetY="2"
                              Opacity="1" />
        </ResourceDictionary>
    </Application.Resources>
</Application>